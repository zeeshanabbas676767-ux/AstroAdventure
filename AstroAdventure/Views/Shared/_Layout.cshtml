@{
    Layout = null;
    var username = Session["UserName"] != null ? Session["UserName"].ToString() : null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - AstroAdventure</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Open+Sans&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
          /*  background-image: url('/Content/Images/space3.png');*/
          background-color:black;
            color: #e0e0e0;
            font-family: 'Open Sans', sans-serif;
            overflow-x: hidden;
            transition: background-color var(--transition-speed);
        }

        /* Navbar */
        .navbar {
            box-shadow: 0 0 10px #111;
            background: linear-gradient(#000000);
        }

        .navbar-brand {
            font-family: 'Orbitron', sans-serif;
            font-size: 1rem;
            color: #00bfff !important;
            letter-spacing: 2px;
            transform: scale(1.1);
        }

        .nav-link {
            color: #e0e0e0 !important;
            margin: 0 6px;
            transition: all 0.3s ease;
        }

            .nav-link:hover {
                color: #00bfff !important;
                text-shadow: 0 0 8px #00bfff;
            }

        /* Main container */
        .main-content {
            flex: 1;
            padding: 40px 20px;
        }

        /* Footer */
        footer {
            background: rgba(10, 10, 30, 0.95);
            text-align: center;
            padding: 20px;
            color: #999;
            font-size: 0.9rem;
            border-top: 1px solid #1f1f3a;
        }

            footer a {
                color: #00bfff;
                text-decoration: none;
            }

                footer a:hover {
                    text-decoration: none;
                }

        /* Buttons */
        .btn-space {
            background-color: #00bfff;
            color: #000;
            border: none;
            transition: 0.3s;
        }

            .btn-space:hover {
                background-color: #0088cc;
                color: #fff;
            }

        /* Card styling */
        .space-card {
            background: rgba(20, 20, 40, 0.95);
            border: 1px solid #222;
            border-radius: 12px;
            box-shadow: 0 0 15px rgba(0, 191, 255, 0.1);
            transition: 0.3s;
        }

            .space-card:hover {
                box-shadow: 0 0 20px rgba(0, 191, 255, 0.4);
                transform: translateY(-3px);
            }

        /* Headings */
        h1, h2 {
            font-family: 'Berlin Sans FB';
            transform: scale(2);
            color: #00bfff;
        }

        h3 {
            font-family: Arial;
            color: #00bfff;
        }

        h4 {
            font-family:'Eras ITC';
            color: #00bfff;
            transform: scale(1.5);
            overflow:auto;
            max-width:1100px
        }


        /* ===== CONTAINER ===== */
        .table-wrapper {
            width: 100%;
            overflow-x: auto;
            background: rgba(0, 0, 0, 0.4);
            border-radius: 12px;
            padding: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.4);
        }

        /* ===== TABLE ===== */
        .table-dark {
            width: 100%;
            border-collapse: collapse;
            border-radius: 10px;
            overflow: hidden;
            font-size: 14px;
            line-height: 1.3;
        }

            .table-dark th, .table-dark td {
                padding: 8px 10px;
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
                vertical-align: middle;
            }

            .table-dark th {
                background-color: #181a1b;
                color: #8ecaff;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .table-dark tr:hover td {
                background-color: #111;
                transition: 0.25s;
            }

            .table-dark td {
                color: #e5e7eb;
            }

        /* ===== PROFILE PICTURE ===== */
        .user-img {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            object-fit: cover;
            box-shadow: 0 0 5px rgba(0,0,0,0.3);
        }

        /* ===== PASSWORD CELL ===== */
        .password-hash-cell {
            max-width: 300px;
            word-break: break-all;
            white-space: normal;
        }

        /* ===== ACTION BUTTONS ===== */
        .action-buttons {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
        }

            .action-buttons a {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 32px;
                height: 32px;
                border-radius: 50%;
                background: rgba(255,255,255,0.08);
                transition: background 0.3s ease;
            }

                .action-buttons a:hover {
                    background: rgba(255,255,255,0.15);
                }

                .action-buttons a.edit i {
                    color: dodgerblue;
                }

                .action-buttons a.details i {
                    color: white;
                }

                .action-buttons a.delete i {
                    color: red;
                }
        /*..........................................................*/

        /* ====== NAVBAR STYLING ====== */
        .astro-navbar {
           /* background: linear-gradient(90deg, rgba(0,0,0,0.3) 0%, #004e92 100%);*/
            padding: 0.3rem 1.5rem;
            transition: all 0.3s ease-in-out;
            font-family: 'Poppins', sans-serif;
        }

            /* Brand */
            .astro-navbar .brand-logo {
                width: 55px;
                height: 55px;
                object-fit: cover;
                transition: transform 0.3s ease;
            }

            /*     .astro-navbar .brand-logo:hover {
                    transform: rotate(5deg) scale(1.05);
                }*/

            .astro-navbar .brand-text {
                color: #00bfff;
                font-family: 'Orbitron', sans-serif;
                font-size: 1.3rem;
                letter-spacing: 1px;
            }

        /* Links */
        .navbar-nav .nav-link {
            color: #dfe6e9 !important;
            font-weight: 500;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            position: relative;
        }

            .navbar-nav .nav-link:hover {
                color: #00bfff !important;
                transform: translateY(-2px);
            }

                   .navbar-nav .nav-link::after {
                content: "";
                position: absolute;
                bottom: 0;
                left: 10%;
                width: 0;
                height: 2px;
                background-color: #00bfff;
                transition: width 0.3s ease;
            }
                .navbar-nav .nav-link:hover::after {
                    width: 80%;
                }


        /* Buttons for Login / SignUp */
        .btn-login, .btn-signup {
            border-radius: 8px;
            padding: 6px 14px !important;
            height: 20px;
            width: 50px;
            border: 1px solid transparent;
        }

        .btn-login {
            background-color: #00bfff;
            color: #fff !important;
        }

            .btn-login:hover {
                background-color: black;
                color: white
            }

        .btn-signup {
            background-color: #00bfff;
            color: #fff !important;
        }

            .btn-signup:hover {
                background-color: black;
                color: white
            }

        /* ====== USER MENU ====== */
        .user-avatar {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border: 2px solid #00bfff;
            transition: transform 0.3s ease;
        }
        .user-avatar1 {
            width: 50px;
            height: 50px;
            object-fit: cover;
            transition: transform 0.3s ease;
        }

           /* .user-avatar:hover {
                transform: scale(1.1);
            }*/

        .user-dropdown {
            background: #ffffff;
            border-radius: 12px;
            border: 1px solid #00bfff;
            min-width: 250px;
            padding: 10px 0;
        }

        .user-avatar-lg {
            width: 100px;
            height: 100px;
           /* border: 3px solid #00bfff;*/
            object-fit: cover;
        }
        /* Mobile nav spacing */
        @@media (max-width: 991px) {
            .astro-navbar {
                padding: 0.8rem;
            }

            .navbar-nav {
                gap: 0.5rem;
            }
        }
        /* Disable blue underline animation for user image area */
        .navbar-nav .user-menu .nav-link::after {
            content: none !important;
        }



        .download-button {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 10px 25px;
            border: none;
            border-radius: 25px;
            overflow: hidden;
            cursor: pointer;
            /* base look */
            background-color: dodgerblue; /* #4CAF50 */
            color: white;
            font-size: 16px;
            font-weight: bold;
            transition: color 0.4s ease-in-out;
        }

            /* text container (always above everything) */
            .download-button span {
                position: relative;
                z-index: 2; /* make text the topmost layer */
                transition: color 0.4s ease-in-out;
            }

            /* black overlay behind text */
            .download-button::before {
                content: "";
                position: absolute;
                inset: 0;
                background-color: white;
                z-index: 1; /* below text, above green background */
                transform: scaleX(0);
                transform-origin: right;
                transition: transform 1.4s cubic-bezier(0.19, 1, 0.22, 1);
                border-radius: 25px;
            }

            /* green base behind everything */
            .download-button::after {
                content: "";
                position: absolute;
                inset: 0;
                background-color: dodgerblue;
                z-index: 0; /* very back */
                border-radius: 25px;
            }

            /* on hover */
            .download-button:hover::before {
                transform: scaleX(1);
                transform-origin: left;
            }

            /* text turns white on hover */
            .download-button:hover span {
                color:black;
            }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark astro-navbar sticky-top shadow-lg">
        <div class="container">
            <!-- Brand -->
            <a class="nav-link p-0 rounded-circle" href="@Url.Action("Index", "Home")" style="width: 70px; height: 64px; border-radius: 26px; display: flex;">
                <img src="~/Content/Images/logo1.png"
                     alt="Logo"
                     class="rounded-circle user-avatar1"style="width:55px;height:55px;" />
            </a>

            <!-- Toggler -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Nav Links -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center gap-1">
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Home")">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "tblArticle")">Articles</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "tblPlanet")">Planets</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "tblStar")">Stars</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "tblMission")">Missions</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "tblCategory")">Category</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "tblUser")">Users</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "tblImage")">Image</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "tblComment")">Comments</a></li>

                    @if (Session["UserID"] != null)
                    {
                        <li class="nav-item dropdown user-menu">
                            <a class="nav-link p-0" href="#" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" style="width:50px;margin-right:123px;border-radius:20px;display:flex">
                                <img src="@Url.Content(Session["ProfileImage"] != null ? Session["ProfileImage"].ToString() : "~/Content/Images/default-user.png")"
                                     alt="User" title="@Session["FullName"]"
                                     class="rounded-circle user-avatar" />
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end user-dropdown shadow">
                                <li class="text-center">
                                    <img id="profileImageDropdown" src="@(Session["ProfileImage"] ?? Url.Content("~/Content/Images/default-avatar.png"))"
                                         class="rounded-circle user-avatar-lg mb-2" alt="Avatar" style="cursor: pointer;" title="Click to change profile picture" />
                                    <!-- Hidden File Input -->
                                    <input type="file" id="imageUpload" accept="image/*" style="display:none;" />
                                    <div class="fw-semibold">@Session["FullName"]</div>
                                    <small class="text-muted">@Session["Email"]</small>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                @{
                                    var currentUserId = Session["UserID"];
                                    if (currentUserId != null)
                                    {
                                        <li><a class="dropdown-item text-primary fw-semibold" href="@Url.Action("Setting","Account", new { id = currentUserId })"><i class="fa fa-cog me-1"></i> Settings</a></li>
                                    }
                                }

                                <li><a class="dropdown-item text-danger fw-semibold" href="@Url.Action("Logout", "Account")"><i class="fa fa-sign-out-alt me-1"></i> Log out</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li style="width:100px">
                            <button class="download-button" onclick="location.href='@Url.Action("Login", "Account")'">
                                <span>Log In <i class="icon-download"></i></span>
                            </button>
                        </li>
                        <li style="width:120px">
                            <button class="download-button" onclick="location.href='@Url.Action("SignUp", "Account")'">
                                <span>Sign Up <i class="icon-download"></i></span>
                            </button>
                        </li>
                        @*<li class="download-button"><a class="nav-link btn-login" href="@Url.Action("Login", "Account")">  <span>Log In<i class="icon-download"></i></span></a></li>*@
                        @*<li class="nav-item"><a class="nav-link btn-signup" href="@Url.Action("SignUp", "Account")">Sign Up</a></li>*@
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="main-content container">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer>
        <a class="nav-link p-0 rounded-circle" href="@Url.Action("Index", "Home")" style="width: 70px; height: 64px; border-radius: 26px;margin:auto">
            <img src="~/Content/Images/logo1.png"
                 alt="Logo"
                 class="rounded-circle user-avatar1" style="width:90px;height:90px;" />
        </a> @*<h5 class="mt-4" style="color:dodgerblue;font-family:'Eras ITC';text-align:left">AstroAdventure</h5>*@
        <div class="mt-5" style="margin-left:418px">
            <ul class="navbar-nav ms-auto flex-row gap-5">
                <li class="nav-item"><a class="nav-link" href="@Url.Action("About", "Home")">About Us</a></li>
                <li class="nav-item"><a class="nav-link" href="@Url.Action("Contact", "Home")">Contact</a></li>
                <li class="nav-item"><a class="nav-link" href="@Url.Action("Privacy_Policy", "Home")">Privacy Policy</a></li>
            </ul>
        </div>
        <p class="mt-3">© @DateTime.Now.Year AstroAdventure | Created By: Zeeshan Abbas | Explore the Universe with Us 🚀</p>

    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        // ✅ Use consistent IDs from your HTML
        const profileImageDropdown = document.getElementById("profileImageDropdown"); // image inside dropdown
        const profileImage = document.querySelector(".user-avatar"); // image in navbar (outside dropdown)
        const imageUpload = document.getElementById("imageUpload"); // hidden file input

        if (profileImageDropdown && imageUpload) {

            // 👆 When user clicks profile image inside dropdown
            profileImageDropdown.addEventListener("click", () => {
                imageUpload.click();
            });

            // 👇 When user selects a new image
            imageUpload.addEventListener("change", function () {
                const file = this.files[0];
                if (!file) return;

                const reader = new FileReader();
                reader.onload = function (e) {
                    const imageData = e.target.result;

                    // ✅ Instant preview for both images
                    if (profileImageDropdown) profileImageDropdown.src = imageData;
                    if (profileImage) profileImage.src = imageData;
                };
                reader.readAsDataURL(file);

                // ✅ Upload to server (optional)
                const formData = new FormData();
                formData.append("file", file);
                formData.append("userId", '@Session["UserID"]');

                fetch('@Url.Action("UploadProfileImage", "Account")', { // 👈 change controller if needed
                    method: "POST",
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        console.log("Profile image updated successfully");
                    } else {
                        alert("Failed to upload image.");
                    }
                })
                .catch(err => console.error("Error uploading image:", err));
            });
        }
    });
</script>
