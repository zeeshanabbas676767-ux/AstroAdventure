@model AstroAdventure.Models.tblImage
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>

    /* Base button style */
    .btn {
        display: inline-block;
        padding: 10px 22px;
        font-size: 15px;
        font-weight: 600;
        border-radius: 10px;
        border: none;
        cursor: pointer;
        color: white;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 3px 10px rgba(0, 0, 0, 0.2);
    }
    /* Info (Back) button */
    .btn-outline-info {
        background: linear-gradient(135deg, #17a2b8, #20c997);
    }

        .btn-outline-info:hover {
            background: linear-gradient(135deg, #138496, #17a2b8);
            color: white
        }
</style>
<h2 style="text-align:center">Image</h2>
<div>
    <dl class="row g-3 mt-3">
        <dt class="col-sm-3"><strong>Title</strong></dt>
        <dd class="col-sm-9"> @(Model.tblArticle != null ? Model.tblArticle.Title : "—")</dd>
        <hr />
        <dt class="col-sm-3 mt-4"><strong>Planet</strong></dt>
        <dd class="col-sm-9"> @(Model.tblPlanet != null ? Model.tblPlanet.Name : "—")</dd>
        <hr />
        <dt class="col-sm-3 mt-4"><strong>Star</strong></dt>
        <dd class="col-sm-9"> @(Model.tblStar != null ? Model.tblStar.Name : "—")</dd>
        <hr />
        <dt class="col-sm-3"><strong>Image</strong></dt>
        <dd class="col-sm-9">
            @if (!string.IsNullOrEmpty(Model.Url))
            {
                <img src="@Url.Content(Model.Url)"
                     alt="@Model.AltText"
                     class="img-fluid rounded shadow-sm"
                     style="max-width: 100px; height: auto;" />
            }
            else
            {
                <span class="text-muted">No image available</span>
            }
        </dd>
        <hr />
        <dt class="col-sm-3 mt-4"><strong>Alt_Text</strong></dt>
        <dd class="col-sm-9"> @Html.DisplayFor(model => model.AltText)</dd>
        <hr />
    </dl>
    <div class="mt-6">
        @Html.ActionLink("Back", "Index", null, new { @class = "btn btn-outline-info" })
    </div>
</div>