@model AstroAdventure.Models.tblMission
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>

    /* Style dropdown box */
    select {
        background-color: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #ffffff;
        padding: 8px 12px;
        border-radius: 8px;
        width: 100%;
    }

        /* Style dropdown options */
        select option {
            background-color: #1e293b; /* dark slate */
            color: #ffffff;
        }

            /* Highlight on hover */
            select option:hover {
                background-color: #4f46e5; /* indigo */
                color: #ffffff;
            }
    /* Base button style */
    .btn {
        display: inline-block;
        padding: 10px 22px;
        font-size: 15px;
        font-weight: 600;
        border-radius: 10px;
        border: none;
        cursor: pointer;
        color: white;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 3px 10px rgba(0, 0, 0, 0.2);
    }

    /* Primary (Create) button */
    .btn-outline-primary {
        background: linear-gradient(135deg, #007bff, #00b4ff);
    }

        .btn-outline-primary:hover {
            background: linear-gradient(135deg, #0056b3, #0088cc);
        }

    /* Secondary (Clear / Cancel) button */
    .btn-outline-secondary {
        background: linear-gradient(135deg, #6c757d, #9199a1);
    }

        .btn-outline-secondary:hover {
            background: linear-gradient(135deg, #565e64, #7a8288);
        }

    /* Info (Back) button */
    .btn-outline-info {
        background: linear-gradient(135deg, #17a2b8, #20c997);
    }

        .btn-outline-info:hover {
            background: linear-gradient(135deg, #138496, #17a2b8);
            color: white
        }

    /* Optional: Add subtle glowing hover effect */
    .btn:hover {
        filter: brightness(1.1);
    }

    /* Button layout */
    .mt-6.flex {
        display: flex;
        gap: 15px;
        margin-top: 20px;
    }
</style>
<h2 style="text-align:center">Missions</h2>
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
<div class="form-horizontal">
    @Html.ValidationSummary(true, "", new { @class = "text-red-400 mb-4" })
    <div class="row g-3 mt-3">
        <div class="col-md-3">
            @Html.LabelFor(model => model.MissionName, htmlAttributes: new { @class = "control-label col-md-2" })
            @Html.EditorFor(model => model.MissionName, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.MissionName, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(model => model.LaunchDate, htmlAttributes: new { @class = "control-label col-md-2" })
            @Html.EditorFor(model => model.LaunchDate, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.LaunchDate, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(model => model.EndDate, htmlAttributes: new { @class = "control-label col-md-2" })
            @Html.EditorFor(model => model.EndDate, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.EndDate, "", new { @class = "text-danger" })
        </div>
    </div>
    <div class="row g-3">
        <div class="col-md-3 mt-5">
            @Html.LabelFor(model => model.Objective, htmlAttributes: new { @class = "control-label col-md-2" })
            @Html.EditorFor(model => model.Objective, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Objective, "", new { @class = "text-danger" })
        </div>
        <div class="col-md-3 mt-5">
            @Html.LabelFor(model => model.RelatedPlanetID, "RelatedPlanetID", htmlAttributes: new { @class = "control-label col-md-2" })
            @Html.DropDownList("RelatedPlanetID", null, htmlAttributes: new { @class = "form-control" })
            @Html.ValidationMessageFor(model => model.RelatedPlanetID, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="mt-6 flex">
        <input type="submit" value="Create" class="btn btn-outline-primary" />

        @if (Model.MissionID > 0)
        {
            @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-outline-secondary" })
        }
        else
        {
            <input type="reset" value="Clear" class="btn btn-outline-secondary" />
        }

        @Html.ActionLink("Back", "Index", null, new { @class = "btn btn-outline-info" })
    </div>
</div>
            }

