@model IEnumerable<AstroAdventure.Models.tblUser>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 style="text-align:center; color:#3b82f6;">User</h2>
<p>
    @Html.ActionLink("Create New", "Create", null, new { @class = "btn btn-outline-primary", style = "color:white;font-weight:600" })
</p>

<div class="table-wrapper">
    <table class="table table-dark">
        <thead>
            <tr>
                <th>Profile Picture</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>User Name</th>
                <th>Password Hash</th>
                <th>Active</th>
                <th>Address</th>
                <th>Created At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ProfileImagePath))
                        {
                            <img src="@Url.Content(item.ProfileImagePath)" class="user-img" />
                        }
                        else
                        {
                            <span style="color:gray;">No Picture</span>
                        }
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.FullName)</td>
                    <td>@Html.DisplayFor(modelItem => item.Email)</td>
                    <td>@Html.DisplayFor(modelItem => item.UserName)</td>
                    <td class="password-hash-cell">@Html.DisplayFor(modelItem => item.PasswordHash)</td>
                    <td>@Html.DisplayFor(modelItem => item.IsActive)</td>
                    <td>@Html.DisplayFor(modelItem => item.Address)</td>
                    <td>@Html.DisplayFor(modelItem => item.CreatedAt)</td>
                    <td>
                        <div class="action-buttons">
                            <a href="@Url.Action("Edit", new { id = item.UserID })" class="edit" title="Edit">
                                <i class="fa fa-edit"></i>
                            </a>
                            <a href="@Url.Action("Details", new { id = item.UserID })" class="details" title="Details">
                                <i class="fa fa-file-alt"></i>
                            </a>
                            <a href="@Url.Action("Delete", new { id = item.UserID })" class="delete" title="Delete">
                                <i class="fa fa-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
